# Pipeline run artifacts (regenerated each run)
cleanup_pages_done_*.json
cleanup_pages.json
email_body.txt
telegram_msg.txt
jobs_rows.json

# Discovery & verification batch files (intermediate pipeline data)
discovery_*.json
verify_batch_*.json
verified_candidates.json

# Raw CSV exports (may contain passwords/credentials)
*.csv

# Environment / secrets
.env
*.env

# OS files
.DS_Store
Thumbs.db

# Git worktrees (auto-managed by git, not for tracking)
.claude/worktrees/

# Playwright MCP artifacts (screenshots, logs, session data)
.playwright-mcp/

# ── Cross-platform runtime artifacts (Windows + macOS) — added for Mac/Codex port ──
__pycache__/
*.pyc
.DS_Store
autopilot_debug_profile/
autopilot_profile_clone/
.env
# Codex local config should NOT be committed (per-machine secrets/paths)
.codex/config.toml

# ── Volatile run artifacts (regenerated each pipeline/dry-run; should not be committed) ──
# NOTE: outputs/ contains real submission records that ARE tracked — do NOT ignore the whole dir.
# Ignore only the per-run audit logs + the mutable state file a dry-run rewrites.
outputs/**/apply_audit_*.json
runs/**/apply_audit_*.json
apply_audit_*.json

# ── SECRETS — never commit (per-machine, local only) ──
# OAuth credentials, client secrets, tokens, and the MCP server config all live
# outside the repo (~/.google_workspace_mcp/ and ~/.claude.json). Guard against
# anyone ever copying them in. Templates live in setup/ instead.
**/client_secret*.json
**/.google_workspace_mcp/**
**/credentials/*.json
.claude.json
**/*token*.json
peopleadmin_*_creds.json
